# Copy this file to .env and fill in your own keys.
# Neither this file nor .env should ever be committed with real values.

# Google Gemini API key — used for routing, generation, and LLM-judge evaluation.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Pinecone API key — used for vector storage, semantic search, and embeddings.
# Get one at https://app.pinecone.io/
PINECONE_API_KEY=
